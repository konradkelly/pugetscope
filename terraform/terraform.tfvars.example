# Copy to terraform.tfvars (gitignored — see terraform/.gitignore) and adjust.
# All values below are the defaults already baked into variables.tf; you
# only need entries here for the ones you want to override.

# aws_region = "us-west-2"

# Open SSH (22) and the K8s API (6443) to your own IP. Find it with
# `curl -s https://checkip.amazonaws.com`. Leave empty to rely solely on
# SSM Session Manager (see terraform/README.md).
# admin_cidrs = ["203.0.113.4/32"]

# control_plane_count = 1
# worker_count         = 1
# control_plane_instance_type = "t3.medium"
# worker_instance_type        = "t3.small"

# Existing EC2 key pair name, only needed if you want direct SSH instead of
# SSM Session Manager.
# ssh_key_name = "my-key"
