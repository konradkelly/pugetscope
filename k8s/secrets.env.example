POSTGRES_USER=pugetscope
POSTGRES_PASSWORD=pugetscope
POSTGRES_DB=pugetscope

OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Non-AWS forward proxy for OpenSky calls only — OpenSky blocks connections
# from AWS IP ranges (see ingestion/src/config.ts). EC2-only; leave blank for
# local dev where the block doesn't apply. "http://user:pass@host:port".
OPENSKY_PROXY_URL=

# Optional — see ingestion/.env.example. Leave blank to disable FIDS enrichment.
AERODATABOX_API_KEY=
