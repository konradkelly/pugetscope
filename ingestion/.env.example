# Create an OpenSky account at https://opensky-network.org, then
# create an API client on your account page to get these values.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Defaults below match docker-compose.yml — override only if you're
# running Postgres/Redis elsewhere.
DATABASE_URL=postgres://pugetscope:pugetscope@localhost:5433/pugetscope
REDIS_URL=redis://localhost:6379

POLL_INTERVAL_MS=30000

# Optional — FIDS route enrichment (docs/SPEC.md §12 tier 1). Without this,
# route enrichment falls back to the adsbdb/own-track-inference tiers only.
# Sign up for AeroDataBox on RapidAPI to get a key:
# https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# FIDS is a TIER 2 endpoint (2 units/call). Budget by plan:
#   BASIC (free): 600 units/mo  -> 300 calls/mo  -> 3h+ interval only
#   PRO ($5):     6000 units/mo -> 3000 calls/mo -> 30min (~1440/mo) is safe
AERODATABOX_API_KEY=
FIDS_AIRPORT_ICAO=KSEA
FIDS_REFRESH_INTERVAL_MS=1800000
