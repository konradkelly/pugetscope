# Create an OpenSky account at https://opensky-network.org, then
# create an API client on your account page to get these values.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Defaults below match docker-compose.yml — override only if you're
# running Postgres/Redis elsewhere.
DATABASE_URL=postgres://pugetscope:pugetscope@localhost:5433/pugetscope
REDIS_URL=redis://localhost:6379

POLL_INTERVAL_MS=30000
